{
  "name": "openpatsnap",
  "version": "0.1.0",
  "type": "module",
  "description": "Patsnap CLI - login, manage API keys, configure MCP servers",
  "main": "dist/index.js",
  "bin": {
    "patsnap": "dist/index.js"
  },
  "scripts": {
    "build": "node build.mjs && shx chmod +x dist/index.js",
    "prepare": "node scripts/prepare.mjs",
    "dev": "tsx src/index.ts",
    "typecheck": "tsc --noEmit",
    "test": "vitest run"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "axios": "^1.7.0",
    "commander": "^14.0.0",
    "comment-json": "^4.6.2",
    "inquirer": "^8.2.4",
    "node-forge": "^1.4.0",
    "picocolors": "^1.1.0",
    "yaml": "^2.8.3",
    "yocto-spinner": "^1.1.0"
  },
  "devDependencies": {
    "@types/inquirer": "^8.2.4",
    "@types/node": "^20.0.0",
    "@types/node-forge": "^1.3.14",
    "esbuild": "^0.27.0",
    "shx": "^0.4.0",
    "tsx": "^4.19.2",
    "typescript": "^5.9.3",
    "vitest": "^3.2.4"
  }
}
