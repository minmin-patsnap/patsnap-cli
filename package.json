{
  "name": "@patsnap/cli",
  "version": "0.1.0",
  "type": "module",
  "description": "Patsnap CLI - login, manage API keys, configure MCP servers",
  "main": "dist/index.js",
  "bin": {
    "patsnap": "dist/index.js"
  },
  "scripts": {
    "build": "node build.mjs && shx chmod +x dist/index.js",
    "dev": "tsx src/index.ts",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "prepublishOnly": "pnpm run build"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "files": ["dist", "README.md", "package.json"],
  "devDependencies": {
    "@types/node": "^20.0.0",
    "axios": "^1.7.0",
    "commander": "^14.0.0",
    "esbuild": "^0.27.0",
    "inquirer": "^8.2.4",
    "@types/inquirer": "^8.2.4",
    "keytar": "^7.9.0",
    "picocolors": "^1.1.0",
    "shx": "^0.4.0",
    "tsx": "^4.19.2",
    "typescript": "^5.9.3",
    "vitest": "^3.2.4"
  },
  "dependencies": {},
  "pnpm": {
    "onlyBuiltDependencies": ["esbuild", "keytar"]
  }
}
